# Local development only. Never commit a real .env file (see .gitignore).
#
# In production on vps.codes.hr, DATABASE_URL is auto-injected by the
# platform when "Provision database" is toggled on for this project — do not
# set it manually there (see vps/MANAGED_PROJECT_GUIDE.md).

# Postgres connection string for local dev / running scripts/migrate.mjs
# against a throwaway Postgres container.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/todo

# next-auth secret used to sign/encrypt JWTs (introduced in Task 2). Generate
# with: openssl rand -base64 32
AUTH_SECRET=
